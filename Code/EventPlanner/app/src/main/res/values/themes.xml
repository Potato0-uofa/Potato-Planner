<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.EventPlanner" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>
    <style name="Theme.EventPlanner" parent="Base.Theme.EventPlanner" />
    <!-- Add these styles inside your existing <resources> block in res/values/themes.xml -->

    <!-- Blue toggle switch (for Organizers & Admins notifications) -->
    <style name="SwitchBlueTheme" parent="Theme.AppCompat.Light">
        <item name="colorControlActivated">#4A90D9</item>
        <item name="colorSwitchThumbNormal">#CCCCCC</item>
        <item name="android:colorForeground">#AAAAAA</item>
    </style>

    <!-- Gray toggle switch (for App Updates - off state) -->
    <style name="SwitchGrayTheme" parent="Theme.AppCompat.Light">
        <item name="colorControlActivated">#888888</item>
        <item name="colorSwitchThumbNormal">#CCCCCC</item>
        <item name="android:colorForeground">#AAAAAA</item>
    </style>
</resources>