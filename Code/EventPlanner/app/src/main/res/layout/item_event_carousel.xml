<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="#3A3347">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Event image -->
        <ImageView
            android:id="@+id/carousel_event_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Event image" />

        <!-- Gradient overlay for text readability -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/carousel_gradient_overlay" />

        <!-- Top bar: category + date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="18dp">

            <!-- Category badge -->
            <TextView
                android:id="@+id/carousel_event_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/carousel_category_badge"
                android:textColor="#C498D0"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textAllCaps="true"
                android:text="Category" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Date badge -->
            <TextView
                android:id="@+id/carousel_event_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/carousel_category_badge"
                android:textColor="#E0E0E0"
                android:textSize="11sp"
                android:text="Date" />
        </LinearLayout>

        <!-- Bottom info section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingBottom="22dp"
            android:paddingTop="8dp">

            <!-- Event name -->
            <TextView
                android:id="@+id/carousel_event_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:text="Event Name" />

            <!-- Divider line -->
            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:background="#C498D0" />

            <!-- Organizer row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_person"
                    android:tint="#C498D0"
                    android:contentDescription="Organizer icon" />

                <TextView
                    android:id="@+id/carousel_event_organizer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="Organizer" />
            </LinearLayout>

            <!-- Location row -->
            <LinearLayout
                android:id="@+id/carousel_location_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/carousel_event_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#BBBBBB"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="Location" />
            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.cardview.widget.CardView>
