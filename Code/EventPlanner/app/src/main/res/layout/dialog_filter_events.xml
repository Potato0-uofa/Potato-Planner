<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="500dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Availability date filter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/filter_date_checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available on date:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <EditText
            android:id="@+id/filter_date_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="YYYY-MM-DD"
            android:inputType="text"
            android:enabled="false"
            android:layout_marginBottom="16dp" />

        <!-- Capacity filter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/filter_capacity_checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Minimum capacity:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <EditText
            android:id="@+id/filter_capacity_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 50"
            android:inputType="number"
            android:enabled="false"
            android:layout_marginBottom="16dp" />

        <!-- Tags filter -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter by Tags:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/tag_entertainment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entertainment"
            android:textSize="15sp"/>

        <CheckBox
            android:id="@+id/tag_sports"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sports"
            android:textSize="15sp"/>

        <CheckBox
            android:id="@+id/tag_cooking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cooking"
            android:textSize="15sp"/>

        <CheckBox
            android:id="@+id/tag_outdoors"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Outdoors"
            android:textSize="15sp"/>

        <CheckBox
            android:id="@+id/tag_gaming"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gaming"
            android:textSize="15sp"/>

        <CheckBox
            android:id="@+id/tag_music"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Music"
            android:textSize="15sp"/>

        <CheckBox
            android:id="@+id/tag_active"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active"
            android:textSize="15sp"/>

        <CheckBox
            android:id="@+id/tag_art"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Art"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <!-- Sort order -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sort by:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/sort_radio_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/sort_none"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Default"
                android:textSize="15sp"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/sort_alphabetical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alphabetical (A–Z)"
                android:textSize="15sp"/>

            <RadioButton
                android:id="@+id/sort_date_old_new"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date: Old to New"
                android:textSize="15sp"/>

            <RadioButton
                android:id="@+id/sort_date_new_old"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date: New to Old"
                android:textSize="15sp"/>

        </RadioGroup>

        <!-- Clear filters button -->
        <Button
            android:id="@+id/filter_clear_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear All Filters"
            android:textAllCaps="false"
            android:backgroundTint="#C498D0"
            android:textColor="#4C2162"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>