<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- ── Title ── -->

        <ImageButton
            android:id="@+id/exit_button_edit_event"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:background="#00FFFFFF"
            app:layout_constraintEnd_toStartOf="@+id/textView6"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#000000" />

        <TextView
            android:id="@+id/textView6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Edit Event Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ── Registration START label ── -->
        <TextView
            android:id="@+id/textView_reg_start_label"
            android:layout_width="196dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Registration Start Date:"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView6" />

        <!-- ── Registration START EditText ── -->
        <EditText
            android:id="@+id/registrationStartDate_edit"
            android:layout_width="193dp"
            android:layout_height="48dp"
            android:hint="YYYY-MM-DD"
            android:inputType="text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/textView_reg_start_label"
            app:layout_constraintTop_toBottomOf="@+id/textView6"
            app:layout_constraintBottom_toBottomOf="@+id/textView_reg_start_label" />

        <!-- ── Registration END label ── -->
        <TextView
            android:id="@+id/textView7"
            android:layout_width="196dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Registration End Date:"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView_reg_start_label" />

        <!-- ── (YYYY/MM/DD) hint ── -->
        <TextView
            android:id="@+id/textView8"
            android:layout_width="196dp"
            android:layout_height="24dp"
            android:text="(YYYY/MM/DD)"
            android:textAlignment="center"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView7" />

        <!-- ── Registration END EditText ── -->
        <EditText
            android:id="@+id/registrationEndDate_edit"
            android:layout_width="193dp"
            android:layout_height="48dp"
            android:hint="YYYY-MM-DD"
            android:inputType="text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/textView7"
            app:layout_constraintTop_toBottomOf="@+id/textView_reg_start_label"
            app:layout_constraintBottom_toBottomOf="@+id/textView8" />

        <!-- ── Geolocation label ── -->
        <TextView
            android:id="@+id/textView9"
            android:layout_width="196dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Geolocation Requirement:"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView8" />

        <!-- ── Geolocation CheckBox ── -->
        <CheckBox
            android:id="@+id/geolocation_private_edit"
            android:layout_width="40dp"
            android:layout_height="44dp"
            android:layout_marginEnd="128dp"
            android:scaleX="2"
            android:scaleY="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/textView9"
            app:layout_constraintTop_toTopOf="@+id/textView9"
            app:layout_constraintBottom_toBottomOf="@+id/textView9" />

        <!-- ── Waiting List Capacity label ── -->
        <TextView
            android:id="@+id/textView_attendee_label"
            android:layout_width="196dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Number of Attendees:"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView9" />

        <EditText
            android:id="@+id/attendee_count"
            android:layout_width="110dp"
            android:layout_height="41dp"
            android:hint="e.g. 50"
            android:inputType="number"
            app:layout_constraintBottom_toBottomOf="@+id/textView_attendee_label"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.1"
            app:layout_constraintStart_toEndOf="@+id/textView_attendee_label"
            app:layout_constraintTop_toTopOf="@+id/textView_attendee_label" />

        <TextView
            android:id="@+id/textView10"
            android:layout_width="196dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Waiting List Capacity:"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView_attendee_label" />

        <!-- ── Waitlist limit CheckBox ── -->

        <CheckBox
            android:id="@+id/max_capacity_check_edit"
            android:layout_width="40dp"
            android:layout_height="44dp"
            android:layout_marginEnd="128dp"
            android:scaleX="2"
            android:scaleY="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/textView10"
            app:layout_constraintTop_toTopOf="@+id/textView10"
            app:layout_constraintBottom_toBottomOf="@+id/textView10" />

        <!-- ── Waitlist limit EditText ── -->
        <EditText
            android:id="@+id/waitlist_capacity_edit"
            android:layout_width="110dp"
            android:layout_height="41dp"
            android:ems="10"
            android:hint="e.g. 100"
            android:inputType="number"
            app:layout_constraintBottom_toBottomOf="@+id/textView10"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/max_capacity_check_edit"
            app:layout_constraintTop_toTopOf="@+id/textView10" />

        <Button
            android:id="@+id/settings_event_tags_button"
            android:layout_width="154dp"
            android:layout_height="49dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/regular_button_bg"
            android:text="Edit Tags"
            android:textAllCaps="false"
            android:textColor="@color/regular_button_text"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView10" />

        <!-- ── Create Event button ── -->

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>