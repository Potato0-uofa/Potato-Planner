<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- ── Title ── -->
        <ImageButton
            android:id="@+id/exit_button_new_public_event"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:background="#00FFFFFF"
            app:layout_constraintEnd_toStartOf="@+id/textView6"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#000000" />

        <TextView
            android:id="@+id/textView6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="New Public Event"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ── Upload Poster ── -->
        <Button
            android:id="@+id/public_event_photo_upload_button"
            android:layout_width="154dp"
            android:layout_height="49dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/regular_button_bg"
            android:text="Upload Poster"
            android:textAllCaps="false"
            android:textColor="@color/regular_button_text"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView6" />

        <!-- ── Registration START label ── -->
        <TextView
            android:id="@+id/textView_reg_start_label"
            android:layout_width="196dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Registration Start Date:"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/public_event_photo_upload_button" />

        <!-- ── Registration START EditText ── -->
        <EditText
            android:id="@+id/registrationStartDate_public_setup"
            android:layout_width="193dp"
            android:layout_height="48dp"
            android:hint="YYYY-MM-DD"
            android:inputType="text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/textView_reg_start_label"
            app:layout_constraintTop_toBottomOf="@+id/public_event_photo_upload_button"
            app:layout_constraintBottom_toBottomOf="@+id/textView_reg_start_label"/>

        <!-- ── Registration END label ── -->
        <TextView
            android:id="@+id/textView7"
            android:layout_width="196dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Registration End Date:"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView_reg_start_label" />

        <!-- ── (YYYY/MM/DD) hint ── -->
        <TextView
            android:id="@+id/textView8"
            android:layout_width="196dp"
            android:layout_height="24dp"
            android:text="(YYYY/MM/DD)"
            android:textAlignment="center"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView7" />

        <!-- ── Registration END EditText ── -->
        <EditText
            android:id="@+id/registrationEndDate_public_setup"
            android:layout_width="193dp"
            android:layout_height="48dp"
            android:hint="YYYY-MM-DD"
            android:inputType="text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/textView7"
            app:layout_constraintTop_toBottomOf="@+id/textView_reg_start_label"
            app:layout_constraintBottom_toBottomOf="@+id/textView8"/>

        <!-- ── Geolocation label ── -->
        <TextView
            android:id="@+id/textView9"
            android:layout_width="196dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Geolocation Requirement:"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView8" />

        <!-- ── Geolocation CheckBox ── -->
        <CheckBox
            android:id="@+id/geolocation_public_setup"
            android:layout_width="40dp"
            android:layout_height="44dp"
            android:layout_marginEnd="128dp"
            android:scaleX="2"
            android:scaleY="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/textView9"
            app:layout_constraintTop_toTopOf="@+id/textView9"
            app:layout_constraintBottom_toBottomOf="@+id/textView9"/>

        <!-- ── Waiting List Capacity label ── -->
        <TextView
            android:id="@+id/textView10"
            android:layout_width="196dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Waiting List Capacity:"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView9" />

        <!-- ── Waitlist limit CheckBox ── -->
        <CheckBox
            android:id="@+id/max_capacity_check_public_setup"
            android:layout_width="40dp"
            android:layout_height="44dp"
            android:layout_marginEnd="128dp"
            android:scaleX="2"
            android:scaleY="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/textView10"
            app:layout_constraintTop_toTopOf="@+id/textView10"
            app:layout_constraintBottom_toBottomOf="@+id/textView10"/>

        <!-- ── Waitlist limit EditText ── -->
        <EditText
            android:id="@+id/waitlist_capacity_public_setup"
            android:layout_width="110dp"
            android:layout_height="41dp"
            android:ems="10"
            android:inputType="number"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/max_capacity_check_public_setup"
            app:layout_constraintTop_toTopOf="@+id/textView10"
            app:layout_constraintBottom_toBottomOf="@+id/textView10"/>

        <!-- ── Create Event button ── -->
        <Button
            android:id="@+id/public_event_create_button"
            android:layout_width="269dp"
            android:layout_height="64dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/regular_button_bg"
            android:text="Create Event"
            android:textAllCaps="false"
            android:textColor="@color/regular_button_text"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView10" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>